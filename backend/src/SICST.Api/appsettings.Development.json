{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=sicst_dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "SICST.Api",
    "Audience": "SICST.Clients",
    "AccessTokenMinutes": 15,
    "Secret": "DevelopmentSecretKeyForJWTTokenSigningProcessMustBeLongerThan32Chars!"
  },
  "Database": {
    "InitializeOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://127.0.0.1:5173",
      "https://127.0.0.1:5173"
    ]
  }
}
